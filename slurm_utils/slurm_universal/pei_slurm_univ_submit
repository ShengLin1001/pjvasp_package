#!/bin/bash
set -euo pipefail

# Generic, software-neutral Slurm batch submission engine.
#
# Iterate the first-level subdirectories of a root dir and perform a
# per-directory ACTION selected by --mode. Chunking (--chunks) is an orthogonal
# option that splits the directories into K groups and submits one parent job
# per group; it is meaningful only for the sequential modes.
#
# Usage:
#   pei_slurm_univ_submit --mode parallel|each-subdir|single-alloc [options]
#   pei_slurm_univ_submit --chunks K --chunk-parent SCRIPT [options]
#
# Options:
#   --mode MODE                  parallel | each-subdir | single-alloc
#   --root-dir DIR               root dir whose first-level subdirs are jobs (default ./y_dir)
#   --lsubdir a,b,c              comma-separated subdir basenames (default: all)
#   --submit-script SCRIPT       Slurm script to sbatch       (parallel / each-subdir)
#   --run-cmd "CMD ..."          command run inside each dir  (single-alloc)
#   --skip-if-file-contains F M  skip a dir when file F contains marker M
#   --chunks K                   split dirs into K chunks, sbatch --chunk-parent per chunk
#   --chunk-parent SCRIPT        parent Slurm script submitted per chunk (with --chunks)
#   --dry-run                    print actions without submitting/running
#
# Modes (the per-directory ACTION):
#   parallel      sbatch SUBMIT_SCRIPT in each dir, do not wait
#   each-subdir   sbatch --wait SUBMIT_SCRIPT in each dir, then recheck skip marker
#   single-alloc  run RUN_CMD inside each dir (exit 0 done / 10 skipped / other failed)

_lib="$(command -v pei_slurm_univ_lib.sh || true)"
[[ -n "$_lib" ]] || { echo "❌ ERROR: pei_slurm_univ_lib.sh not found in PATH" >&2; exit 1; }
# shellcheck source=/dev/null
source "$_lib"

mode=""
root_dir="./y_dir"
lsubdir=""
submit_script=""
run_cmd=""
skip_file=""
skip_marker=""
num_chunks=1
chunk_parent=""
dry_run=false

while (( $# > 0 )); do
    case "$1" in
        --mode)           mode="$2"; shift 2 ;;
        --root-dir)       root_dir="$2"; shift 2 ;;
        --lsubdir)        lsubdir="$2"; shift 2 ;;
        --submit-script)  submit_script="$2"; shift 2 ;;
        --run-cmd)        run_cmd="$2"; shift 2 ;;
        --skip-if-file-contains)
            [[ $# -ge 3 ]] || ps_fail "--skip-if-file-contains needs <file> <marker>"
            skip_file="$2"; skip_marker="$3"; shift 3 ;;
        --chunks)         num_chunks="$2"; shift 2 ;;
        --chunk-parent)   chunk_parent="$2"; shift 2 ;;
        --dry-run)        dry_run=true; shift ;;
        -h|--help)        sed -n '4,40p' "$0"; exit 0 ;;
        *)                ps_fail "unknown argument: $1" ;;
    esac
done

[[ "$num_chunks" =~ ^[1-9][0-9]*$ ]] || ps_fail "--chunks must be a positive integer: $num_chunks"
[[ -z "$skip_file" || "$skip_file" != */* ]] || ps_fail "--skip-if-file-contains file must be a basename inside each job dir: $skip_file"

# --- chunk path: split all subdirs into K groups and submit one parent each ---
if (( num_chunks > 1 )); then
    [[ -n "$chunk_parent" ]] || ps_fail "--chunks requires --chunk-parent <slurm-script>"
    parent_path="$(ps_resolve_script_path "$chunk_parent")"
    [[ -d "$root_dir" ]] || ps_fail "root directory not found: $root_dir"

    mapfile -t names < <(find "$root_dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)
    total=${#names[@]}
    (( total > 0 )) || ps_fail "no subdirectories found below root_dir: $root_dir"
    (( num_chunks <= total )) || ps_fail "--chunks ($num_chunks) cannot exceed number of subdirs ($total)"

    base=$(( total / num_chunks ))
    rem=$(( total % num_chunks ))
    offset=0
    for (( c=1; c<=num_chunks; c++ )); do
        count=$base
        (( c <= rem )) && count=$(( count + 1 ))
        group=""
        for (( i=0; i<count; i++ )); do
            group="${group:+$group,}${names[offset + i]}"
        done
        echo ""
        echo "======================================================================"
        echo "🚀 Submitting chunk $c / $num_chunks  ($count dirs)"
        echo "  root-dir : $root_dir"
        echo "  lsubdir  : $group"
        echo "  command  : sbatch $parent_path \"$root_dir\" \"$group\""
        echo "======================================================================"
        [[ "$dry_run" == true ]] || sbatch "$parent_path" "$root_dir" "$group"
        offset=$(( offset + count ))
    done
    exit 0
fi

# --- non-chunk path: iterate dirs and perform the per-mode ACTION ------------
case "$mode" in
    parallel|each-subdir|single-alloc) ;;
    "") ps_fail "--mode is required (parallel|each-subdir|single-alloc)" ;;
    *)  ps_fail "invalid --mode: $mode" ;;
esac

submit_path=""
if [[ "$mode" == parallel || "$mode" == each-subdir ]]; then
    [[ -n "$submit_script" ]] || ps_fail "--submit-script is required for --mode $mode"
    submit_path="$(ps_resolve_script_path "$submit_script")"
    [[ "$dry_run" == true ]] || command -v sbatch >/dev/null 2>&1 || ps_fail "sbatch command not found in PATH"
fi
if [[ "$mode" == single-alloc ]]; then
    [[ -n "$run_cmd" ]] || ps_fail "--run-cmd is required for --mode single-alloc"
fi

ps_resolve_job_dirs "$root_dir" "$lsubdir"

start_dir="$(pwd)"
skipped=0
ok_count=0
fail_count=0
submitted=0
failed_dirs=()

echo "🚀 mode=$mode    root=$root_dir    lsubdir=${lsubdir:-all}"
[[ -n "$submit_path" ]] && echo "📄 submit script: $submit_path"
[[ -n "$run_cmd" ]]     && echo "▶️  per-dir command: $run_cmd"
[[ -n "$skip_file" ]]   && echo "⏭️  skip when $skip_file contains: $skip_marker"
[[ "$dry_run" == true ]] && echo "🧪 dry-run (no submission)"

skip_done() {
    [[ -n "$skip_file" && -f "$skip_file" ]] && grep -qF "$skip_marker" "$skip_file"
}

for dir in "${PS_JOB_DIRS[@]}"; do
    cd "$start_dir"
    echo ""
    echo "================ 📁 $dir"
    if ! cd "$dir"; then
        echo "❌ ERROR: cannot enter directory: $dir" >&2
        fail_count=$((fail_count + 1)); failed_dirs+=("$dir"); continue
    fi
    echo "📍 $(pwd)"

    case "$mode" in
        parallel)
            if skip_done; then
                echo "✅ skip: $skip_file contains completion marker"
                skipped=$((skipped + 1)); continue
            fi
            echo "▶️  sbatch $submit_path"
            [[ "$dry_run" == true ]] && continue
            if sbatch "$submit_path"; then
                ok_count=$((ok_count + 1))
            else
                echo "❌ sbatch failed in $(pwd)" >&2
                fail_count=$((fail_count + 1)); failed_dirs+=("$dir")
            fi
            ;;

        each-subdir)
            if skip_done; then
                echo "✅ skip: $skip_file contains completion marker"
                skipped=$((skipped + 1)); continue
            fi
            echo "▶️  sbatch --wait $submit_path"
            [[ "$dry_run" == true ]] && continue
            if sbatch --wait "$submit_path"; then
                echo "✅ child job ended with success status"
            else
                echo "⚠️  child job ended with non-zero status: $?"
            fi
            submitted=$((submitted + 1))
            if skip_done; then
                echo "✅ converged after child job"
                ok_count=$((ok_count + 1))
            else
                echo "❌ not converged after child job" >&2
                fail_count=$((fail_count + 1)); failed_dirs+=("$dir")
            fi
            ;;

        single-alloc)
            echo "▶️  $run_cmd"
            [[ "$dry_run" == true ]] && continue
            set +e
            eval "$run_cmd"
            status=$?
            set -e
            case "$status" in
                0)  ok_count=$((ok_count + 1)) ;;
                10) skipped=$((skipped + 1)) ;;
                *)  fail_count=$((fail_count + 1)); failed_dirs+=("$dir") ;;
            esac
            ;;
    esac
done

cd "$start_dir"
echo ""
echo "================ 📊 Summary"
case "$mode" in
    parallel)     echo "submitted=$ok_count    skipped=$skipped    failed=$fail_count" ;;
    each-subdir)  echo "submitted=$submitted    converged=$ok_count    skipped=$skipped    failed=$fail_count" ;;
    single-alloc) echo "completed=$ok_count    skipped=$skipped    failed=$fail_count" ;;
esac

ps_report_failures "❌ Failed / unconverged directories:" ${failed_dirs[@]+"${failed_dirs[@]}"}

if (( fail_count > 0 )); then
    echo "❌ Done with failures."
    exit 1
fi
echo "🎉 Done!"
exit 0
