#!/bin/bash
# taken from https://github.com/BinglunYin/vasp_utils
# revised by J. Pei, 2025-05-29
#

# ---------- Colors ----------
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ---------- Help ----------
# Dispatcher: every option maps to one y_* workflow dir + its plot script. This list is
# the only place a user can discover which workflows are plottable, so keep it in sync
# with the case block at the bottom.
print_help(){
    echo -e "${GREEN}pei_vasp_plot_all${NC} - Find every y_* workflow dir under . and post-process it"
    echo ""
    echo -e "${YELLOW}Usage:${NC}"
    echo -e "  $(basename "$0") ${GREEN}<workflow>${NC}"
    echo ""
    echo -e "${YELLOW}Workflows:${NC}"
    echo -e "  ${GREEN}-convergence${NC}      y_convergence     ENCUT / KPOINTS convergence"
    echo -e "  ${GREEN}-stretch${NC}          y_stretch         strain-energy curve"
    echo -e "  ${GREEN}-neb${NC}              y_neb             NEB barrier"
    echo -e "  ${GREEN}-hoec_energy${NC}      y_hoec_energy     2nd/3rd/4th-order elastic constants"
    echo -e "  ${GREEN}-kpar_nocre${NC}       y_kpar_ncore      KPAR/NCORE timing (alias ${GREEN}-kpar_ncore${NC})"
    echo -e "  ${GREEN}-E_in_1_2_bulk${NC}    y_E_in_1_2_bulk   uniaxial / biaxial bulk energy"
    echo ""
    echo -e "${YELLOW}Notes:${NC}"
    echo -e "  - Run it at the level of ${BLUE}y_full_relax${NC}, i.e. one level ${BLUE}above${NC} the y_* dirs."
    echo -e "    It recurses with find, so a single call plots every match under the tree."
    echo -e "  - Each plot script is run ${BLUE}inside${NC} its workflow dir and re-runs pei_vasp_univ_post."
    echo -e "  - Only run it once the jobs have ${GREEN}finished${NC}; it reads OUTCARs, it does not submit."
    echo ""
    echo -e "${YELLOW}Example:${NC}"
    echo -e "  $(basename "$0") -convergence      # after the ENCUT/KPOINTS tests finish"
    echo -e "  $(basename "$0") -stretch          # equilibrium lattice constant"
    echo -e "  $(basename "$0") -hoec_energy      # solve HOEC in every y_hoec_energy found"
    echo ""
}

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    print_help
    exit 0
fi

if [ -z "$1" ]; then      # empty is true
    echo -e "==>  Please indicate what to plot. Abort!  (see ${GREEN}$(basename "$0") --help${NC})"
    exit
fi


d0=`pwd`

sub_plot_all(){
    workdir="$1"
    mycmd=$2
    echo "==> workdir: "  "$workdir"
    echo "==> mycmd: "     $mycmd

    mylist=`find ./ -type d -name "$workdir"`
    echo mylist $mylist
    for dirn in $mylist ; do
        cd $dirn
        echo -e "\n==>" `pwd`
    
        # move to $cmd
        #pei_vasp_univ_post 
        #python3  $mycmd
        $mycmd
    
        cd $d0
    done


    echo -e "\n==> ${FUNCNAME[0]} summary: "
    
    
    for dirn in $mylist ; do
        cd $dirn
        temproot=`pwd`
        echo -e "\n==> $temproot"
        workdir2=y_dir
        # dir counts
        dc=`find ./ -type d -name $workdir2  -print | wc -l`
        echo -e "\n==> Number of $workdir2: $dc "
        mylist2=$(find ./ -type d -name "$workdir2" -exec dirname {} \;)
        for dirn2 in $mylist2 ; do
            echo -e "\n==> $dirn2"
            cat -n $dirn2/y_post_time.txt
            grep -n "Your highest band" $dirn2/y_post_warning.txt
        done
        cd $d0
        echo " "
    done
    echo " "

}




case "$1" in


    -convergence)
        workdir=y_convergence
        mycmd=$PJ_MYMETAL/vasp_utils/vasp_workflow_bulk/pei_vasp_plot_convergence.py
        sub_plot_all  $workdir  $mycmd 
        ;;


    -neb)
        workdir=y_neb
        mycmd=$PJ_MYMETAL/vasp_utils/vasp_workflow_bulk/pei_vasp_plot_neb.py
        sub_plot_all  $workdir  $mycmd 
        ;;


    -stretch)
        workdir=y_stretch
        mycmd=$PJ_MYMETAL/vasp_utils/vasp_workflow_bulk/pei_vasp_plot_stretch.py
        sub_plot_all  $workdir  $mycmd
        ;;


    # higher-order elastic constants; the script itself runs pei_vasp_univ_post
    # over the whole tree, so no separate post step is needed here
    -hoec_energy)
        workdir=y_hoec_energy
        mycmd=$PJ_MYMETAL/vasp_utils/vasp_workflow_bulk/pei_vasp_plot_hoec_energy.py
        sub_plot_all  $workdir  $mycmd
        ;;

    # KPAR/NCORE elapsed-time benchmark. Keep -kpar_nocre as the requested public
    # spelling; -kpar_ncore is accepted as a convenience alias.
    -kpar_nocre|-kpar_ncore)
        workdir=y_kpar_ncore
        mycmd=$PJ_MYMETAL/vasp_utils/vasp_workflow_bulk/pei_vasp_plot_kpar_ncore
        sub_plot_all  $workdir  $mycmd
        ;;

    -E_in_1_2_bulk)
        workdir=y_E_in_1_2_bulk
        mycmd=$PJ_MYMETAL/vasp_utils/vasp_workflow_others/pei_vasp_plot_E_in_1_2_bulk.py
        sub_plot_all  $workdir  $mycmd 
        ;;

    *)
        echo -e "==>  Option $1 not recognized. Abort!  (see ${GREEN}$(basename "$0") --help${NC})"
        exit
        ;;
esac



