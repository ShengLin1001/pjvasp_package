#!/usr/bin/env python3
# J. Pei, 2026-07-15
# pei_vasp_plot_kpar_ncore
#  >>> Post-process the KPAR/NCORE benchmark generated by pei_vasp_run_kpar_ncore.
#
#  pei_vasp_univ_post first scrapes Elapsedtime and energy(sigma->0); this reads both,
#  converts time to minutes and energy to E-E0 in meV/atom, and draws two stacked NCORE
#  panels. The real work lives in mymetal.post.kpar_ncore.
#
#  Writes into y_kpar_ncore/:
#      p_post_kpar_ncore.txt   sortable timing/energy table + fastest KPAR/NCORE
#      p_post_kpar_ncore.pdf   time and relative energy vs NCORE, one curve per KPAR
#
#  All arguments are optional -- with none it behaves like its siblings, so
#      pei_vasp_plot_all  -kpar_ncore
#  works (plot_all cd's into y_kpar_ncore, which is auto-detected below).
#
#  >>> Example usage:
#      pei_vasp_plot_kpar_ncore                        # at the level of y_full_relax
#      cd y_kpar_ncore && pei_vasp_plot_kpar_ncore     # from inside (as plot_all does)
#      pei_vasp_plot_kpar_ncore -skip_univ_post       # reuse y_post_time/data.txt

import argparse
import sys
from pathlib import Path

# Kept in sync with the ">>> Example usage" block at the top of this file; argparse only
# shows what we hand it, so the header comment alone never reaches a --help reader.
EPILOG = """\
most common:
  pei_vasp_plot_kpar_ncore                          # at the level of y_full_relax
  cd y_kpar_ncore && pei_vasp_plot_kpar_ncore       # from inside (as plot_all does)
  pei_vasp_plot_kpar_ncore -skip_univ_post         # reuse scraped y_post_time/data.txt
  pei_vasp_plot_all -kpar_nocre                     # every y_kpar_ncore under the tree

writes into y_kpar_ncore/:
  p_post_kpar_ncore.txt   timing/energy table + the measured fastest KPAR/NCORE
  p_post_kpar_ncore.pdf   time and relative energy vs NCORE, one curve per KPAR

notes:
  run it only once the benchmark jobs have finished; -skip_univ_post skips re-scraping
  the OUTCARs, so use it whenever you are only restyling the figure.
"""

parser = argparse.ArgumentParser(
    description="Plot KPAR/NCORE times and relative energies from a finished tree.",
    epilog=EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
parser.add_argument("-dir", default="y_kpar_ncore",
                    help="Workflow directory (default y_kpar_ncore).")
parser.add_argument("-skip_univ_post", action="store_true",
                    help="Reuse existing y_post_time.txt and y_post_data.txt "
                         "instead of running pei_vasp_univ_post.")
parser.add_argument("-fig", default=None, help="Optional output figure path.")
parser.add_argument("-txt", default=None, help="Optional output table path.")
args = parser.parse_args()

# Guard AFTER parse_args, so --help still answers under a stale interpreter: the shebang is
# /usr/bin/env python3, which is 3.6 on this box. Only the mymetal import below needs 3.10
# (the library annotates with subscripted generics like dict[tuple[int, int], float]).
if sys.version_info < (3, 10):
    raise SystemExit("pei_vasp_plot_kpar_ncore needs the active Python >= 3.10 environment")

from mymetal.post.kpar_ncore import post_kpar_ncore

# pei_vasp_plot_all cd's into y_kpar_ncore before calling us, so ./y_kpar_ncore is gone;
# accept both that and being run one level up, next to y_full_relax.
path_dir = Path(args.dir)
if not path_dir.is_dir() and Path.cwd().name == args.dir:
    path_dir = Path.cwd()

print("Directory      :", path_dir)
print("Skip univ_post :", args.skip_univ_post)
print("Figure         :", args.fig)
print("Table          :", args.txt)

# pei_vasp_univ_post is a subprocess; line-buffer stdout so our messages stay ordered
# around its output instead of arriving in one block at the end.
sys.stdout.reconfigure(line_buffering=True)

path_dir = path_dir.resolve()
print("🟢 ===== pei_vasp_plot_kpar_ncore in %s" % path_dir)
post_kpar_ncore(path_workflow=str(path_dir), run_post=not args.skip_univ_post,
                save_fig_path=args.fig, save_txt_path=args.txt)
