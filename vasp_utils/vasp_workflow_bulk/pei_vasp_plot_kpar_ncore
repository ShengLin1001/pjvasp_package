#!/usr/bin/env python3
# J. Pei, 2026-07-15
# pei_vasp_plot_kpar_ncore
#  >>> Post-process the KPAR/NCORE benchmark generated by pei_vasp_run_kpar_ncore.
#
#  pei_vasp_univ_post first scrapes one Elapsedtime per y_dir into y_post_time.txt; this
#  reads those seconds, converts them to minutes, and draws all six KPAR curves in one
#  NCORE timing panel. The real work lives in mymetal.post.kpar_ncore.
#
#  Writes into y_kpar_ncore/:
#      p_post_kpar_ncore.txt   sortable timing table + the measured fastest KPAR/NCORE
#      p_post_kpar_ncore.pdf   elapsed time vs NCORE, one curve per KPAR
#
#  All arguments are optional -- with none it behaves like its siblings, so
#      pei_vasp_plot_all  -kpar_ncore
#  works (plot_all cd's into y_kpar_ncore, which is auto-detected below).
#
#  >>> Example usage:
#      pei_vasp_plot_kpar_ncore                        # at the level of y_full_relax
#      cd y_kpar_ncore && pei_vasp_plot_kpar_ncore     # from inside (as plot_all does)
#      pei_vasp_plot_kpar_ncore --skip-univ-post       # reuse an existing y_post_time.txt

import argparse
import sys
from pathlib import Path

# Guard before importing mymetal: the library annotates with 3.10 subscripted generics
# (dict[tuple[int, int], float]), which fail at import on an older active env.
if sys.version_info < (3, 10):
    raise SystemExit("pei_vasp_plot_kpar_ncore needs the active Python >= 3.10 environment")

from mymetal.post.kpar_ncore import post_kpar_ncore

parser = argparse.ArgumentParser(
    description="Plot KPAR/NCORE elapsed times from a finished y_kpar_ncore tree.")
parser.add_argument("--dir", default="y_kpar_ncore",
                    help="Workflow directory (default y_kpar_ncore).")
parser.add_argument("--skip-univ-post", action="store_true",
                    help="Reuse an existing y_post_time.txt instead of running "
                         "pei_vasp_univ_post.")
parser.add_argument("--fig", default=None, help="Optional output figure path.")
parser.add_argument("--txt", default=None, help="Optional output table path.")
args = parser.parse_args()

# pei_vasp_plot_all cd's into y_kpar_ncore before calling us, so ./y_kpar_ncore is gone;
# accept both that and being run one level up, next to y_full_relax.
path_dir = Path(args.dir)
if not path_dir.is_dir() and Path.cwd().name == args.dir:
    path_dir = Path.cwd()

print("Directory      :", path_dir)
print("Skip univ_post :", args.skip_univ_post)
print("Figure         :", args.fig)
print("Table          :", args.txt)

# pei_vasp_univ_post is a subprocess; line-buffer stdout so our messages stay ordered
# around its output instead of arriving in one block at the end.
sys.stdout.reconfigure(line_buffering=True)

path_dir = path_dir.resolve()
print("🟢 ===== pei_vasp_plot_kpar_ncore in %s" % path_dir)
post_kpar_ncore(path_workflow=str(path_dir), run_post=not args.skip_univ_post,
                save_fig_path=args.fig, save_txt_path=args.txt)
