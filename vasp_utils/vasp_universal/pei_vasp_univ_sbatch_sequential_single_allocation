#!/bin/bash

# Run unfinished VASP calculations below y_dir one at a time in one allocation.
# Re-running this command is safe for completed directories: they are skipped.

# Usage:
#   pei_vasp_univ_sbatch_sequential_single_allocation [root_dir] [vasp_executable] [lsubdir] [completion_marker] [smaller_ediff_marker]
# Example:
#   pei_vasp_univ_sbatch_sequential_single_allocation ./y_dir vasp_std "" "reached required accuracy" "please rerun with smaller EDIFF"

# 目录根路径，默认使用当前目录下的 y_dir
root_dir="${1:-./y_dir}"
# VASP 可执行文件名
vasp_executable="${2:-vasp_std}"
# 逗号分隔的 root_dir 下一级子目录 basename 列表；为空时遍历 root_dir 下全部一级目录
lsubdir="${3:-}"
# OUTCAR 中用于判断计算完成的标记
completion_marker="${4:-reached required accuracy}"
# 如果需要更小的 EDIFF 来完成计算，可以通过第五个参数传入，否则默认提示用户重新运行并使用更小的 EDIFF
smaller_ediff_marker="${5:-please rerun with smaller EDIFF}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"


if [[ ! -d "$root_dir" ]]; then
    echo "❌ ERROR: sequential job directory not found: $root_dir" >&2
    exit 1
fi

# 启用 nullglob 以防止没有目录时 glob 模式被原样保留，将为 job_dirs 赋值一个空数组
shopt -s nullglob
if [[ -z "$lsubdir" ]]; then
    job_dirs=("$root_dir"/*/)
else
    IFS=',' read -r -a lsubdir_items <<< "$lsubdir"
    job_dirs=()
    for subdir in "${lsubdir_items[@]}"; do
        if [[ -z "$subdir" ]]; then
            echo "❌ ERROR: empty directory name in lsubdir: $lsubdir" >&2
            exit 1
        fi
        if [[ "$subdir" == */* ]]; then
            echo "❌ ERROR: lsubdir entries must be basenames below $root_dir: $subdir" >&2
            exit 1
        fi
        job_dir="${root_dir%/}/$subdir/"
        if [[ ! -d "$job_dir" ]]; then
            echo "❌ ERROR: lsubdir directory not found: $job_dir" >&2
            exit 1
        fi
        job_dirs+=("$job_dir")
    done
fi
if (( ${#job_dirs[@]} == 0 )); then
    echo "❌ ERROR: no calculation directories found below: $root_dir" >&2
    exit 1
fi

start_dir="$(pwd)"
single_job_runner="$(command -v pei_vasp_univ_sbatch || true)"
if [[ -z "$single_job_runner" && -x "$script_dir/pei_vasp_univ_sbatch" ]]; then
    single_job_runner="$script_dir/pei_vasp_univ_sbatch"
fi
completed_count=0
skipped_count=0
failed_count=0
unfinished_or_failed_dirs=()

if [[ -z "$single_job_runner" ]]; then
    echo "❌ ERROR: single job runner not found in PATH: pei_vasp_univ_sbatch" >&2
    exit 1
fi

echo "🚀 ==> Running VASP jobs sequentially below $root_dir"
echo "🧩 Single job runner: $single_job_runner"

for dir in "${job_dirs[@]}"; do

    cd "$start_dir" || exit 1
    "$single_job_runner" "$dir" "$vasp_executable" "$completion_marker" "$smaller_ediff_marker"
    status=$?

    if (( status == 0 )); then
        completed_count=$((completed_count + 1))
    elif (( status == 10 )); then
        skipped_count=$((skipped_count + 1))
    else
        # status == 1
        failed_count=$((failed_count + 1))
        unfinished_or_failed_dirs+=("$dir")
    fi

done

echo "================ 📊 Summary" 
echo "completed_now=$completed_count    skipped_completed=$skipped_count    unfinished_or_failed=$failed_count"

if (( failed_count > 0 )); then
    echo "❌ Unfinished or failed directories:"
    for dir in "${unfinished_or_failed_dirs[@]}"; do
        echo "  - 📁 $dir"
    done
    echo "❌ Done with unfinished or failed calculations."
    exit 1
fi

echo "🎉 Done!"
exit 0
