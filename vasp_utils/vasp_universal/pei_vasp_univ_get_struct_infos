#!/usr/bin/env python3
"""Extract VASP structure information for each subdirectory in ``y_dir``.

Like ``pei_vasp_univ_post``, the script searches ``-root`` (default ``.``) for
every ``y_dir`` and writes each table next to the ``y_dir`` it came from, so a
multi-mode tree such as ``y_hoec_energy/*/y_dir`` is done in one go. Pass
``-no_recursive`` to fall back to a single explicit work directory.

Functions:
    get_args: Parse command-line arguments.
    get_lworkdir: Resolve the work directories to process.
    get_structure_info: Read lattice, thickness, atom count, and CNA counts.
    get_energy: Read the final sigma->0 energy from OUTCAR.
    write_table: Write the fixed-width summary table.
    write_table2: Write the POSCAR/CONTCAR per-phase comparison table.
    run_workdir: Extract one work directory and write its two tables.
    main: Coordinate checks, extraction, and summary output.
"""

from __future__ import annotations

import argparse
import re
import unicodedata
from pathlib import Path
from typing import Any

import numpy as np
from ase.io.vasp import read_vasp
from mymetal.build.film.extrfilm import my_extr_thick
from ovito.io import import_file
from ovito.modifiers import CommonNeighborAnalysisModifier


COL_WIDTH = 20
NA_VALUE = "NA"
BASE_HEADER = [
    "jobn",
    "a1(Å)",
    "a2(Å)",
    "a3(Å)",
    "c(Å)",
    "c3(Å)",
    "energy(eV)",
    "atoms_num",
    "FCC",
    "HCP",
    "BCC",
    "ICO",
    "OTHER",
]
COMPARE_HEADER = [
    "POSCAR_atoms",
    "POSCAR_FCC",
    "POSCAR_HCP",
    "same_atoms",
    "same_FCC",
    "same_HCP",
    "same_FCC_HCP",
]
FLAG_YES = "✅"
FLAG_NO = "❌"
DICT_PHASE_LABEL = {
    "atoms_num": "atoms",
    "FCC": "FCC",
    "HCP": "HCP",
    "BCC": "BCC",
    "ICO": "ICO",
    "OTHER": "OTHER",
}
COMPARE2_HEADER = (
    ["jobn"]
    + [
        str_prefix + str_label
        for str_label in DICT_PHASE_LABEL.values()
        for str_prefix in ("POSCAR_", "CONTCAR_", "same_")
    ]
    + ["same_all"]
)
CROSS_JOB_LABEL = "cross_jobs"
SKIP_VALUE = "-"


def fail(str_msg: str) -> None:
    """Exit on a structural precondition error."""
    print("❌ ERROR: " + str_msg)
    raise SystemExit(1)


def warn(str_msg: str) -> None:
    """Print a recoverable batch warning."""
    print("⚠️ " + str_msg)


def get_help_epilog() -> str:
    """Build the --help epilog with outputs and common usage examples.

    Returns:
        Epilog text.
    """
    return "\n".join(
        [
            "outputs:",
            "  p_post_struct_infos.txt   per-job a/c/energy/CNA summary",
            "                            (-compare_poscar appends POSCAR columns)",
            "  p_post_struct_infos2.txt  per-phase POSCAR/CONTCAR counts with same",
            "                            checks (✅/❌); the " + CROSS_JOB_LABEL + " footer row",
            "                            checks each count column across all jobs",
            "  both tables are written next to each y_dir found, like the",
            "  y_post_* files of pei_vasp_univ_post",
            "",
            "common usage:",
            "  pei_vasp_univ_get_struct_infos                      # every y_dir under .",
            "  pei_vasp_univ_get_struct_infos -compare_poscar",
            "  pei_vasp_univ_get_struct_infos -compare_poscar -strict",
            "  pei_vasp_univ_get_struct_infos -structure POSCAR -output p_post_struct_infos_poscar.txt",
            "",
            "batch usage (every y_dir under a tree, e.g. y_hoec_energy/*/y_dir):",
            "  cd y_hoec_energy && pei_vasp_univ_get_struct_infos",
            "  pei_vasp_univ_get_struct_infos -root ./y_hoec_energy -compare_poscar",
            "",
            "single work directory (no search):",
            "  pei_vasp_univ_get_struct_infos -no_recursive -workdir ./y_dir",
        ]
    )


def get_args() -> argparse.Namespace:
    """Parse command-line arguments.

    Returns:
        Parsed argparse namespace.
    """
    parser = argparse.ArgumentParser(
        description=(
            "Extract a/c/energy/atom-count/CNA information from VASP "
            "calculations under y_dir."
        ),
        epilog=get_help_epilog(),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "-root",
        default=".",
        help="Root searched recursively for every -workdir. Default: .",
    )
    parser.add_argument(
        "-workdir",
        default="./y_dir",
        help=(
            "Directory containing calculation subdirectories. Only its name is "
            "used as the search target, unless -no_recursive treats it as the "
            "one work directory. Default: ./y_dir"
        ),
    )
    parser.add_argument(
        "-no_recursive",
        action="store_true",
        help=(
            "Do not search -root; process -workdir alone and honour the full "
            "-output/-output2 paths."
        ),
    )
    parser.add_argument(
        "-output",
        default="p_post_struct_infos.txt",
        help=(
            "Output table path. Only its file name is used, next to each y_dir "
            "found. Default: p_post_struct_infos.txt"
        ),
    )
    parser.add_argument(
        "-output2",
        default="p_post_struct_infos2.txt",
        help=(
            "POSCAR/CONTCAR per-phase comparison table path. Only its file name "
            "is used, next to each y_dir found. "
            "Default: p_post_struct_infos2.txt"
        ),
    )
    parser.add_argument(
        "-structure",
        default="CONTCAR",
        help="VASP structure file to summarize. Default: CONTCAR",
    )
    parser.add_argument(
        "-compare_poscar",
        action="store_true",
        help="Also append POSCAR atom/FCC/HCP comparison columns to the main table.",
    )
    parser.add_argument(
        "-strict",
        action="store_true",
        help=(
            "Return exit code 1 when any row fails, any POSCAR comparison "
            "mismatches, any count column differs across jobs, or any work "
            "directory is empty."
        ),
    )
    return parser.parse_args()


def get_path_checked(path_raw: str, str_label: str) -> Path:
    """Resolve and validate an existing directory path.

    Args:
        path_raw: Raw path string from the command line.
        str_label: Human-readable label for diagnostics.

    Returns:
        Resolved directory path.
    """
    path_dir = Path(path_raw).expanduser().resolve()
    if not path_dir.is_dir():
        fail(str_label + " does not exist or is not a directory: " + str(path_dir))
    return path_dir


def get_path_output(path_raw: str, path_base: Path | None = None) -> Path:
    """Resolve one output path and ensure its parent directory exists.

    Args:
        path_raw: Raw output path string from the command line.
        path_base: Directory that hosts the table in recursive mode; the raw
            path then contributes only its file name.

    Returns:
        Resolved output path.
    """
    if path_base is None:
        path_output = Path(path_raw).expanduser().resolve()
    else:
        path_output = (path_base / Path(path_raw).name).resolve()
    path_output.parent.mkdir(parents=True, exist_ok=True)
    return path_output


def get_lworkdir(args: argparse.Namespace) -> list[Path]:
    """Resolve the work directories to process.

    Args:
        args: Parsed argparse namespace.

    Returns:
        Work directory list: every directory named like -workdir under the
        -root tree, or the single -workdir when -no_recursive is given.
    """
    if args.no_recursive:
        return [get_path_checked(args.workdir, "workdir")]

    path_root = get_path_checked(args.root, "root")
    str_name = Path(args.workdir).name
    lworkdir = [path_item for path_item in path_root.rglob(str_name) if path_item.is_dir()]
    # rglob never yields the root itself, so running inside a y_dir would
    # otherwise find nothing.
    if path_root.name == str_name:
        lworkdir.append(path_root)
    if not lworkdir:
        fail("No directory named " + str_name + " found under: " + str(path_root))
    return sorted(set(lworkdir))


def get_strain_sort_key(path_subdir: Path) -> tuple[float, int, str]:
    """Sort strain folders as 0, -0.01, +0.01, -0.02, +0.02, ...

    Args:
        path_subdir: Calculation subdirectory.

    Returns:
        Sort key.
    """
    match = re.search(r"([+-]\d+(?:\.\d+)?)", path_subdir.name)
    if match is None:
        return (float("inf"), 0, path_subdir.name)

    float_value = float(match.group(1))
    int_sign_order = 0 if float_value <= 0.0 else 1
    return (abs(float_value), int_sign_order, path_subdir.name)


def get_lsubdir(path_workdir: Path) -> list[Path]:
    """Get first-level calculation directories under the work directory.

    Args:
        path_workdir: Directory containing calculation subdirectories.

    Returns:
        Sorted calculation directory list.
    """
    lsubdir = [path_item for path_item in path_workdir.iterdir() if path_item.is_dir()]
    return sorted(lsubdir, key=get_strain_sort_key)


def get_energy(path_outcar: Path) -> str:
    """Read the final VASP sigma->0 energy using the legacy grep rule.

    Args:
        path_outcar: OUTCAR path.

    Returns:
        Energy string, or NA when unavailable.
    """
    if not path_outcar.is_file() or path_outcar.stat().st_size == 0:
        return NA_VALUE

    str_energy = NA_VALUE
    with path_outcar.open("r", encoding="utf-8", errors="ignore") as file_in:
        for str_line in file_in:
            if "  without" not in str_line:
                continue
            lfield = str_line.split()
            if len(lfield) >= 7:
                str_energy = lfield[6]
    return str_energy


def get_cna_counts(path_structure: Path) -> dict[str, int]:
    """Compute CNA counts from a VASP structure with OVITO.

    Args:
        path_structure: POSCAR/CONTCAR-like file path.

    Returns:
        CNA count dictionary.
    """
    pipeline = import_file(str(path_structure))
    cna_modifier = CommonNeighborAnalysisModifier(
        mode=CommonNeighborAnalysisModifier.Mode.AdaptiveCutoff
    )
    pipeline.modifiers.append(cna_modifier)
    results = pipeline.compute()
    dict_attr = results.attributes
    return {
        "FCC": int(dict_attr.get("CommonNeighborAnalysis.counts.FCC", 0)),
        "HCP": int(dict_attr.get("CommonNeighborAnalysis.counts.HCP", 0)),
        "BCC": int(dict_attr.get("CommonNeighborAnalysis.counts.BCC", 0)),
        "ICO": int(dict_attr.get("CommonNeighborAnalysis.counts.ICO", 0)),
        "OTHER": int(dict_attr.get("CommonNeighborAnalysis.counts.OTHER", 0)),
    }


def get_structure_info(path_structure: Path) -> dict[str, Any]:
    """Read lattice lengths, thickness, atom count, and CNA counts.

    Args:
        path_structure: POSCAR/CONTCAR-like file path.

    Returns:
        Dictionary with values for output columns.
    """
    if not path_structure.is_file() or path_structure.stat().st_size == 0:
        raise FileNotFoundError(str(path_structure))

    atoms = read_vasp(str(path_structure))
    cell = np.array(atoms.get_cell().copy())
    dict_cna = get_cna_counts(path_structure)
    return {
        "a1": np.linalg.norm(cell[0]),
        "a2": np.linalg.norm(cell[1]),
        "a3": np.linalg.norm(cell[2]),
        "c": my_extr_thick(atoms),
        "c3": atoms.get_cell()[2, 2],
        "atoms_num": len(atoms),
        "FCC": dict_cna["FCC"],
        "HCP": dict_cna["HCP"],
        "BCC": dict_cna["BCC"],
        "ICO": dict_cna["ICO"],
        "OTHER": dict_cna["OTHER"],
    }


def get_row_value(dict_info: dict[str, Any] | None, str_key: str) -> str:
    """Convert one structure field into a printable table value.

    Args:
        dict_info: Structure information dictionary, or None on failure.
        str_key: Field key.

    Returns:
        Printable value.
    """
    if dict_info is None:
        return NA_VALUE
    return str(dict_info.get(str_key, NA_VALUE))


def get_same_flag(dict_left: dict[str, Any] | None, dict_right: dict[str, Any] | None, str_key: str) -> str:
    """Compare one count between two structures.

    Args:
        dict_left: First structure information dictionary.
        dict_right: Second structure information dictionary.
        str_key: Count key.

    Returns:
        YES, NO, or NA.
    """
    if dict_left is None or dict_right is None:
        return NA_VALUE
    return "YES" if dict_left.get(str_key) == dict_right.get(str_key) else "NO"


def get_emoji_flag(str_flag: str) -> str:
    """Convert a YES/NO/NA flag into the emoji table tag.

    Args:
        str_flag: YES, NO, or NA.

    Returns:
        FLAG_YES for YES, FLAG_NO for NO, NA otherwise.
    """
    if str_flag == "YES":
        return FLAG_YES
    if str_flag == "NO":
        return FLAG_NO
    return NA_VALUE


def get_compare_values(
    dict_contcar: dict[str, Any] | None,
    dict_poscar: dict[str, Any] | None,
) -> list[str]:
    """Build POSCAR comparison columns for one row.

    Args:
        dict_contcar: CONTCAR information dictionary.
        dict_poscar: POSCAR information dictionary.

    Returns:
        Comparison column values.
    """
    str_same_atoms = get_same_flag(dict_contcar, dict_poscar, "atoms_num")
    str_same_fcc = get_same_flag(dict_contcar, dict_poscar, "FCC")
    str_same_hcp = get_same_flag(dict_contcar, dict_poscar, "HCP")
    if NA_VALUE in [str_same_fcc, str_same_hcp]:
        str_same_fcc_hcp = NA_VALUE
    else:
        str_same_fcc_hcp = "YES" if str_same_fcc == "YES" and str_same_hcp == "YES" else "NO"

    return [
        get_row_value(dict_poscar, "atoms_num"),
        get_row_value(dict_poscar, "FCC"),
        get_row_value(dict_poscar, "HCP"),
        str_same_atoms,
        str_same_fcc,
        str_same_hcp,
        str_same_fcc_hcp,
    ]


def get_compare2_row(
    str_jobn: str,
    dict_poscar: dict[str, Any] | None,
    dict_contcar: dict[str, Any] | None,
) -> tuple[list[str], str]:
    """Build one POSCAR/CONTCAR per-phase comparison row.

    Args:
        str_jobn: Calculation directory name.
        dict_poscar: POSCAR information dictionary.
        dict_contcar: CONTCAR information dictionary.

    Returns:
        Row values and the overall YES/NO/NA same flag.
    """
    lvalue = [str_jobn]
    lflag: list[str] = []
    for str_key in DICT_PHASE_LABEL:
        str_flag = get_same_flag(dict_contcar, dict_poscar, str_key)
        lflag.append(str_flag)
        lvalue.append(get_row_value(dict_poscar, str_key))
        lvalue.append(get_row_value(dict_contcar, str_key))
        lvalue.append(get_emoji_flag(str_flag))

    if NA_VALUE in lflag:
        str_same_all = NA_VALUE
    elif all(str_item == "YES" for str_item in lflag):
        str_same_all = "YES"
    else:
        str_same_all = "NO"
    lvalue.append(get_emoji_flag(str_same_all))
    return lvalue, str_same_all


def get_cross_flag(lcell: list[str]) -> str:
    """Check whether one count column is identical across all jobs.

    Args:
        lcell: Column values from every job row.

    Returns:
        YES, NO, or NA. A real difference wins over missing data, so NA is
        returned only when the known values agree but some rows are missing.
    """
    lknown = [str_cell for str_cell in lcell if str_cell != NA_VALUE]
    if len(set(lknown)) > 1:
        return "NO"
    if len(lknown) < len(lcell) or not lknown:
        return NA_VALUE
    return "YES"


def get_cross_job_row(lrow2: list[list[str]]) -> tuple[list[str], list[str]]:
    """Build the cross-job consistency footer row for the comparison table.

    Args:
        lrow2: Per-job comparison rows.

    Returns:
        Footer row values and the list of inconsistent column names.
    """
    lvalue = [CROSS_JOB_LABEL]
    lflag: list[str] = []
    lbad: list[str] = []
    for int_col in range(1, len(COMPARE2_HEADER) - 1):
        str_name = COMPARE2_HEADER[int_col]
        if str_name.startswith("same_"):
            lvalue.append(SKIP_VALUE)
            continue
        str_flag = get_cross_flag([lrow[int_col] for lrow in lrow2])
        lflag.append(str_flag)
        lvalue.append(get_emoji_flag(str_flag))
        if str_flag == "NO":
            lbad.append(str_name)

    if lbad:
        str_cross_all = "NO"
    elif NA_VALUE in lflag:
        str_cross_all = NA_VALUE
    else:
        str_cross_all = "YES"
    lvalue.append(get_emoji_flag(str_cross_all))
    return lvalue, lbad


def get_display_width(str_value: str) -> int:
    """Get the terminal display width, counting wide chars as 2.

    Args:
        str_value: Cell text.

    Returns:
        Display width.
    """
    return sum(
        2 if unicodedata.east_asian_width(char) in "FW" else 1 for char in str_value
    )


def get_output_line(lvalue: list[str]) -> str:
    """Format one fixed-width output line.

    Args:
        lvalue: Column values.

    Returns:
        Formatted line.
    """
    # Emoji flags render 2 columns wide but count as 1 char, so plain ljust
    # would shift every later column; pad by display width instead.
    lcell = []
    for value in lvalue:
        str_value = str(value)
        int_pad = max(COL_WIDTH - get_display_width(str_value), 0)
        lcell.append(str_value + " " * int_pad)
    return "".join(lcell).rstrip() + "\n"


def write_table(path_output: Path, lrow: list[list[str]], bool_compare_poscar: bool) -> None:
    """Write output rows to the summary table.

    Args:
        path_output: Output table path.
        lrow: Table rows.
        bool_compare_poscar: Whether POSCAR comparison columns are included.
    """
    lheader = BASE_HEADER + (COMPARE_HEADER if bool_compare_poscar else [])
    with path_output.open("w", encoding="utf-8") as file_out:
        file_out.write(get_output_line(lheader))
        for lvalue in lrow:
            file_out.write(get_output_line(lvalue))


def write_table2(path_output2: Path, lrow2: list[list[str]]) -> None:
    """Write POSCAR/CONTCAR per-phase comparison rows to the second table.

    Args:
        path_output2: Output table path.
        lrow2: Table rows.
    """
    with path_output2.open("w", encoding="utf-8") as file_out:
        file_out.write(get_output_line(COMPARE2_HEADER))
        for lvalue in lrow2:
            file_out.write(get_output_line(lvalue))


def run_workdir(
    path_workdir: Path,
    path_output: Path,
    path_output2: Path,
    args: argparse.Namespace,
) -> dict[str, list[str]] | None:
    """Extract one work directory and write its two tables.

    Args:
        path_workdir: Directory containing calculation subdirectories.
        path_output: Summary table path.
        path_output2: Per-phase comparison table path.
        args: Parsed argparse namespace.

    Returns:
        Issue lists keyed by ``row``, ``failed``, ``mismatch``, and ``cross``,
        or None when the work directory holds no calculation subdirectory.
    """
    ### prepare
    lsubdir = get_lsubdir(path_workdir)
    if not lsubdir:
        warn("No calculation subdirectories found in: " + str(path_workdir))
        return None

    print("================ 📁 Directory")
    print("📍 workdir: " + str(path_workdir))
    print("📍 output : " + str(path_output))
    print("📍 output2: " + str(path_output2))
    print("📍 rows   : " + str(len(lsubdir)))
    print("▶️ Extracting a, c, energy from VASP outputs (OUTCAR, " + args.structure + ")")
    print("▶️ strict: a1 = norm(cell[0]), c = max(z)-min(z), c3 = cell[2,2]")
    print("▶️ compare2: POSCAR vs " + args.structure + " counts for all phases (✅/❌)")
    print("▶️ cross-job: footer row " + CROSS_JOB_LABEL + " checks count columns across jobs")
    if args.compare_poscar:
        print("▶️ compare: " + args.structure + " atoms/FCC/HCP against POSCAR")

    lrow: list[list[str]] = []
    lrow2: list[list[str]] = []
    lfailed: list[str] = []
    lmismatch: list[str] = []
    ### prepare to here

    ### main
    for path_subdir in lsubdir:
        print("================ ▶️ Processing " + path_subdir.name)
        path_structure = path_subdir / args.structure
        path_outcar = path_subdir / "OUTCAR"
        str_energy = get_energy(path_outcar)

        dict_info: dict[str, Any] | None = None
        try:
            dict_info = get_structure_info(path_structure)
        except Exception as exc:
            str_msg = path_subdir.name + " " + args.structure + " failed: " + repr(exc)
            warn(str_msg)
            lfailed.append(str_msg)

        lvalue = [
            path_subdir.name,
            get_row_value(dict_info, "a1"),
            get_row_value(dict_info, "a2"),
            get_row_value(dict_info, "a3"),
            get_row_value(dict_info, "c"),
            get_row_value(dict_info, "c3"),
            str_energy,
            get_row_value(dict_info, "atoms_num"),
            get_row_value(dict_info, "FCC"),
            get_row_value(dict_info, "HCP"),
            get_row_value(dict_info, "BCC"),
            get_row_value(dict_info, "ICO"),
            get_row_value(dict_info, "OTHER"),
        ]

        # The per-phase comparison table always needs POSCAR counts; reuse
        # the CONTCAR-side info when the summarized structure is POSCAR itself.
        dict_poscar: dict[str, Any] | None = None
        if args.structure == "POSCAR":
            dict_poscar = dict_info
        else:
            try:
                dict_poscar = get_structure_info(path_subdir / "POSCAR")
            except Exception as exc:
                str_msg = path_subdir.name + " POSCAR failed: " + repr(exc)
                warn(str_msg)
                lfailed.append(str_msg)

        if args.compare_poscar:
            lvalue.extend(get_compare_values(dict_info, dict_poscar))

        lrow.append(lvalue)

        lvalue2, str_same_all = get_compare2_row(path_subdir.name, dict_poscar, dict_info)
        lrow2.append(lvalue2)
        if str_same_all == "NO":
            lmismatch.append(path_subdir.name)
            warn(path_subdir.name + " POSCAR/" + args.structure + " phase counts mismatch")

    lvalue_cross, lcross = get_cross_job_row(lrow2)
    lrow2.append(lvalue_cross)

    write_table(path_output, lrow, args.compare_poscar)
    write_table2(path_output2, lrow2)

    print("================ 📊 Summary")
    print("✅ rows written: " + str(len(lrow)))
    print("⚠️ failed rows : " + str(len(lfailed)))
    print("⚠️ mismatches  : " + str(len(lmismatch)))
    print("⚠️ cross-job   : " + str(len(lcross)))
    if lfailed:
        print("⚠️ failed row list:")
        for str_item in lfailed:
            print("  - " + str_item)
    if lmismatch:
        print("⚠️ mismatch row list:")
        for str_item in lmismatch:
            print("  - " + str_item)
    if lcross:
        print("⚠️ cross-job inconsistent columns:")
        for str_item in lcross:
            print("  - " + str_item)
    print("🎉 Results saved in " + str(path_output))
    print("🎉 Phase comparison saved in " + str(path_output2))
    ### main to here

    return {
        "row": [lvalue[0] for lvalue in lrow],
        "failed": lfailed,
        "mismatch": lmismatch,
        "cross": lcross,
    }


def write_total_summary(
    lworkdir: list[Path],
    dict_total: dict[Path, dict[str, list[str]]],
    lskipped: list[Path],
) -> None:
    """Print the batch summary over every work directory.

    Args:
        lworkdir: Work directories found.
        dict_total: Issue lists keyed by processed work directory.
        lskipped: Work directories without calculation subdirectories.
    """
    int_row = sum(len(dict_item["row"]) for dict_item in dict_total.values())
    print("================ 📊 Total summary")
    print("📍 workdirs found : " + str(len(lworkdir)))
    print("✅ workdirs done  : " + str(len(dict_total)))
    print("✅ rows written   : " + str(int_row))
    print("⚠️ workdirs empty : " + str(len(lskipped)))
    for path_workdir, dict_item in dict_total.items():
        lissue = []
        for str_key in ("failed", "mismatch", "cross"):
            if dict_item[str_key]:
                lissue.append(str_key + "=" + str(len(dict_item[str_key])))
        str_flag = (FLAG_NO + " " + ", ".join(lissue)) if lissue else FLAG_YES
        print("  " + str_flag + " " + str(path_workdir))
    for path_workdir in lskipped:
        print("  ⚠️ empty " + str(path_workdir))


def main() -> int:
    """Run extraction and return a process exit code."""
    ### check
    args = get_args()
    lworkdir = get_lworkdir(args)
    ### check to here

    ### prepare
    print("================ 📁 Search")
    if args.no_recursive:
        print("📍 root    : - (-no_recursive)")
    else:
        print("📍 root    : " + str(Path(args.root).expanduser().resolve()))
    print("📍 workdirs: " + str(len(lworkdir)) + " x " + Path(args.workdir).name)
    ### prepare to here

    ### main
    dict_total: dict[Path, dict[str, list[str]]] = {}
    lskipped: list[Path] = []
    for path_workdir in lworkdir:
        # Each table lands beside its own y_dir, matching where
        # pei_vasp_univ_post drops its y_post_* files. -no_recursive instead
        # honours the full -output path the caller gave.
        path_base = None if args.no_recursive else path_workdir.parent
        path_output = get_path_output(args.output, path_base)
        path_output2 = get_path_output(args.output2, path_base)

        dict_result = run_workdir(path_workdir, path_output, path_output2, args)
        if dict_result is None:
            lskipped.append(path_workdir)
            continue
        dict_total[path_workdir] = dict_result

    if not dict_total:
        fail(
            "No calculation subdirectories found in any of the "
            + str(len(lworkdir))
            + " work directories."
        )

    # One work directory already printed its own summary above; a second,
    # identical one would just be noise.
    if len(lworkdir) > 1 or lskipped:
        write_total_summary(lworkdir, dict_total, lskipped)
    ### main to here

    bool_bad = any(
        dict_item["failed"] or dict_item["mismatch"] or dict_item["cross"]
        for dict_item in dict_total.values()
    )
    if args.strict and (bool_bad or lskipped):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
