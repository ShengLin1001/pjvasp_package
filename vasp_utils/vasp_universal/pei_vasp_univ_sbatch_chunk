#!/bin/bash
set -euo pipefail

# Usage:
# pei_vasp_univ_sbatch_chunk [root_dir] <num_chunks> <submit_script> [--dry-run]
# pei_vasp_univ_sbatch_chunk ./y_dir 10 pei_slurm_univ_vasp_544_sequential_single_allocation.sh "$@"
# pei_vasp_univ_sbatch_chunk ./y_dir 10 pei_slurm_univ_vasp_544_sequential_each_subdir_sbatch.sh "$@"
#
# Backward-compatible usage:
# pei_vasp_univ_sbatch_chunk 10 pei_slurm_univ_vasp_544_sequential_single_allocation.sh "$@"
# pei_vasp_univ_sbatch_chunk 10 pei_slurm_univ_vasp_544_sequential_each_subdir_sbatch.sh "$@"

usage() {
    echo "Usage: $(basename "$0") [root_dir] <num_chunks> <submit_script> [--dry-run]" >&2
}

echo $(pwd)

if (( $# < 2 || $# > 4 )); then
    usage
    exit 1
fi

root_dir="./y_dir"
explicit_root_dir=false
if [[ "$1" =~ ^[1-9][0-9]*$ ]]; then
    if (( $# > 3 )); then
        usage
        exit 1
    fi
    num_chunks="$1"
    submit_script="$2"
    mode="${3:-}"
else
    if (( $# < 3 )); then
        usage
        exit 1
    fi
    root_dir="$1"
    explicit_root_dir=true
    num_chunks="$2"
    submit_script="$3"
    mode="${4:-}"
fi

if [[ ! "$num_chunks" =~ ^[1-9][0-9]*$ ]]; then
    echo "ERROR: num_chunks must be a positive integer: $num_chunks" >&2
    exit 1
fi

if [[ -n "$mode" && "$mode" != "--dry-run" ]]; then
    usage
    exit 1
fi

if [[ ! -d "$root_dir" ]]; then
    echo "ERROR: root_dir not found: $root_dir" >&2
    exit 1
fi

if [[ -f "$submit_script" ]]; then
    submit_script_path="$submit_script"
else
    submit_script_path=$(command -v "$submit_script" || true)
fi

if [[ -z "${submit_script_path:-}" ]]; then
    echo "ERROR: submit script not found as file or command in PATH: $submit_script" >&2
    exit 1
fi

if [[ ! -r "$submit_script_path" ]]; then
    echo "ERROR: submit script is not readable: $submit_script_path" >&2
    exit 1
fi

mapfile -t dirs < <(find "$root_dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)
total=${#dirs[@]}

if (( total == 0 )); then
    echo "ERROR: no subdirectories found below root_dir: $root_dir" >&2
    exit 1
fi

if (( num_chunks > total )); then
    echo "ERROR: num_chunks ($num_chunks) cannot exceed number of root_dir subdirectories ($total)." >&2
    exit 1
fi

base=$(( total / num_chunks ))
remainder=$(( total % num_chunks ))
offset=0

for (( chunk=1; chunk<=num_chunks; chunk++ )); do
    count=$base
    if (( chunk <= remainder )); then
        count=$(( count + 1 ))
    fi

    lsubdir=""
    for (( i=0; i<count; i++ )); do
        name="${dirs[offset + i]}"
        if [[ -z "$lsubdir" ]]; then
            lsubdir="$name"
        else
            lsubdir="$lsubdir,$name"
        fi
    done

    echo
    echo "========================================================================"
    echo "🚀 Submitting chunk $chunk / $num_chunks"
    echo "------------------------------------------------------------------------"
    echo "  Root directory       : $root_dir"
    echo "  Number of directories : $count"
    echo "  Subdirectories        : $lsubdir"
    echo "  Submit script         : $submit_script_path"
    if [[ "$explicit_root_dir" == true ]]; then
        echo "  Submit command        : sbatch $submit_script_path \"$root_dir\" \"$lsubdir\""
    else
        echo "  Submit command        : sbatch $submit_script_path \"$lsubdir\""
    fi
    echo "========================================================================"
    echo

    if [[ "$mode" != "--dry-run" ]]; then
        if [[ "$explicit_root_dir" == true ]]; then
            sbatch "$submit_script_path" "$root_dir" "$lsubdir"
        else
            sbatch "$submit_script_path" "$lsubdir"
        fi
    fi

    offset=$(( offset + count ))
done
