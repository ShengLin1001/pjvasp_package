#!/bin/bash
set -euo pipefail

# VASP-compatible wrapper around the software-neutral Slurm parallel helper.
#
# Usage:
#   pei_vasp_univ_sbatch_parallel [root_dir] [submit_script] [lsubdir] [completion_marker] [--dry-run]
# Example:
#   pei_vasp_univ_sbatch_parallel ./y_dir pei_slurm_univ_vasp_544.sh "" "reached required accuracy"

root_dir="${1:-./y_dir}"
submit_script="${2:-pei_slurm_univ_vasp_544.sh}"
lsubdir="${3:-}"
completion_marker="${4:-reached required accuracy}"
mode="${5:-}"

if [[ -n "$mode" && "$mode" != "--dry-run" ]]; then
    echo "Usage: $(basename "$0") [root_dir] [submit_script] [lsubdir] [completion_marker] [--dry-run]" >&2
    exit 1
fi

parallel_helper="$(command -v pei_slurm_univ_sbatch_parallel || true)"
if [[ -z "$parallel_helper" ]]; then
    echo "ERROR: parallel helper not found in PATH: pei_slurm_univ_sbatch_parallel" >&2
    exit 1
fi

args=("$root_dir" "$submit_script" "$lsubdir" "--skip-if-file-contains" "OUTCAR" "$completion_marker")
if [[ "$mode" == "--dry-run" ]]; then
    args+=("--dry-run")
fi

"$parallel_helper" "${args[@]}"
