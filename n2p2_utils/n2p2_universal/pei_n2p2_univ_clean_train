### summary：计数 + 释放空间 + 逐个列出被拦截项（永远保留）--------------
print_summary() {
    local item
    printf '\n================ 📊 summary\n'
    if (( HAS_TRAIN )); then
        printf '阶段 1 保留（各族末尾） : %d 个\n' "$N_KEEP"
        printf '阶段 1 %s文件           : %d 个（%s）\n' \
            "$( (( APPLY )) && echo '已删' || echo '将删' )" \
            "$N_DEL" "$(get_human_size "$BYTES_FREED")"
    fi
    if (( HAS_POST )); then
        printf '阶段 2 %s y_dir         : %d 棵%s\n' \
            "$( (( APPLY )) && echo '已回收' || echo '将回收' )" "$N_TREE" \
            "$( (( WANT_SIZE )) && echo "（$(get_human_size "$BYTES_TREE")）" || echo '（体积未统计，加 --size）' )"
        printf '阶段 2 本就无 y_dir     : %d 个\n' "$N_GONE"
        printf '阶段 2 非 job 目录      : %d 个\n' "$N_NOJOB"
        printf '阶段 2 被拦截           : %d 个\n' "${#LBLOCKED[@]}"
        # bash 4.2 下 set -u + 空数组展开会报 unbound variable，故先判长度
        if (( ${#LBLOCKED[@]} > 0 )); then
            for item in "${LBLOCKED[@]}"; do
                printf '   ❌ %s\n' "$item"
            done
        fi
        # 强删项单列：这些 job 的 epoch 数据是【不完整】就被回收的，事后无法追溯
        printf '阶段 2 %s强删           : %d 个\n' \
            "$( (( APPLY )) && echo '已' || echo '将' )" "$N_FORCED"
        if (( ${#LFORCED[@]} > 0 )); then
            for item in "${LFORCED[@]}"; do
                printf '   ⚠️  %s\n' "$item"
            done
        fi
    fi

    if (( APPLY )); then
        printf '🎉 完成。\n'
    else
        printf '⚠️  这是 dry-run，未删任何文件。确认无误后加 --apply 真正执行。\n'
    fi
    if (( FORCE && N_FORCED > 0 )); then
        printf '⚠️  --force 已跳过 epoch 覆盖校验：上列 job 的扫描数据并不完整，%s。\n' \
            "$( (( APPLY )) && echo '已不可恢复' || echo '加 --apply 后将不可恢复' )"
    fi
    printf '================\n'

    (( ${#LBLOCKED[@]} == 0 )) || return 1
    return 0
}

main() {
    ### check：只校验结构性前提（目录存在、至少有一个阶段有活干）
    [[ -n "$ROOT" ]] || fail "未指定 <root>。用法见 --help。"
    [[ -d "$ROOT" ]] || fail "目录不存在：$ROOT"
    ROOT="$(realpath -- "$ROOT")"    # 转绝对路径，后续全程用它（护栏依赖它），无需 chdir
    (( SKIP_TRAIN && SKIP_POST )) && fail "--skip-train 与 --skip-post 同时给出，无事可做。"

    local ydir="$ROOT/y_dir" ypost="$ROOT/y_post"
    if (( ! SKIP_TRAIN )) && [[ -d "$ydir"  ]]; then HAS_TRAIN=1; fi
    if (( ! SKIP_POST  )) && [[ -d "$ypost" ]]; then HAS_POST=1;  fi
    (( HAS_TRAIN || HAS_POST )) \
        || fail "$ROOT 下既无 y_dir 也无 y_post（或都被 --skip-* 关掉了），没什么可清理。"
    # --force 只放行阶段 2 的 epoch 覆盖校验；阶段 2 不跑时它无处生效，提示而非报错
    if (( FORCE && ! HAS_POST )); then
        warn "--force 只作用于阶段 2，而本次阶段 2 未运行，该参数无效果。"
    fi

    ### prepare：preflight 回显
    printf '================ 🧹 pei_n2p2_univ_clean_train\n'
    printf '📁 root       : %s\n' "$ROOT"
    printf '▶️  模式       : %s\n' "$( (( APPLY )) && echo '真删 (--apply)' || echo 'dry-run（不删，仅预览）' )"
    printf '▶️  阶段 1     : %s\n' "$( (( SKIP_TRAIN )) && echo '跳过 (--skip-train)' || { (( HAS_TRAIN )) && echo "y_dir  → $ydir" || echo '无 y_dir，跳过'; } )"
    printf '▶️  阶段 2     : %s\n' "$( (( SKIP_POST  )) && echo '跳过 (--skip-post)'  || { (( HAS_POST  )) && echo "y_post → $ypost" || echo '无 y_post，跳过'; } )"
    printf '▶️  强制       : %s\n' "$( (( FORCE )) && echo '跳过 epoch 覆盖校验 (--force)，形状护栏 / 结构异常仍拦截' || echo '否（校验未过则保留 y_dir）' )"
    printf '================\n'

    ### main：两阶段依次处理（用 if，避免 && 列表末命令的非零返回被 set -e 捕获）
    if (( HAS_TRAIN )); then clean_train_dir "$ydir";  fi
    if (( HAS_POST  )); then clean_post_dir  "$ypost"; fi

    ### summary：被拦截项非空时以 1 退出，提醒人工介入
    print_summary
}

### 参数解析（简单枚举，非法即 fail） ---------------------------------
while (( $# )); do
    case "$1" in
        --apply)           APPLY=1 ;;
        --force)           FORCE=1 ;;
        --include-weights) INCLUDE_WEIGHTS=1 ;;
        --skip-train)      SKIP_TRAIN=1 ;;
        --skip-post)       SKIP_POST=1 ;;
        --size)            WANT_SIZE=1 ;;
        -h|--help|help)    usage 0 ;;
        -*)                fail "未知选项：$1（-h 查看用法）" ;;
        *)                 [[ -z "$ROOT" ]] && ROOT="$1" || fail "多余参数：$1" ;;
    esac
    shift
done

main

