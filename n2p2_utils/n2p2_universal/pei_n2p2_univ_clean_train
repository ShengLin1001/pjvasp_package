#
#   # 1) 先 dry-run 看单个 y_dir 会删什么
#   ./prune_y_dir.sh train/stage0/1/train/y_n2p2_param_scan/y_dir
#
#   # 2) 确认无误后真删（仅诊断族，保留全部 weights）
#   ./prune_y_dir.sh train/stage0/1/train/y_n2p2_param_scan/y_dir --apply
#
#   # 3) 连 weights 也只留最终 epoch（会丢失挑"最优 epoch"的能力，慎用）
#   ./prune_y_dir.sh train/stage0/1/train/y_n2p2_param_scan/y_dir --include-weights --apply
