#!/usr/bin/env bash
# ================================================================ 🧹 pei_n2p2_univ_clean_train
# 清理一个 n2p2 训练/扫描目录（形如 y_n2p2_param_scan / y_n2p2_train）下的中间数据。
# 这类目录的典型结构：
#
#   <root>/
#     y_dir/<job>/                                  ← 阶段 1：nnp-train 工作目录
#     y_post/<job>/properties/y_epoch_scan/         ← 阶段 2：逐 epoch 性质扫描
#         p_post_epoch_{cij,gsfe,stretch}.txt       ← 汇总结果（要留）
#         y_dir/<epoch>/                            ← 逐 epoch 的 LAMMPS 计算（可删）
#
# 阶段 1（--skip-train 关闭）：裁剪 <root>/y_dir 的每个直接子目录。
#   nnp-train 每 50 步为下列文件族各留一个 epoch 快照，post 结束后只需最后一个：
#     neuron-stats / trainpoints / testpoints / trainforces / testforces
#   weights.<elem>.<epoch>.out 默认【不动】(它是势函数本体)，
#   需要时用 --include-weights 才按元素分组各留最终 epoch。
#
# 阶段 2（--skip-post 关闭）：回收 <root>/y_post/*/properties/y_epoch_scan/y_dir。
#   势函数与汇总数据已被 post 复制/聚合出来，逐 epoch 的 LAMMPS 计算目录不再需要。
#   删之前必须通过“epoch 覆盖校验”：
#     每个 p_post_epoch_<name>.txt 都存在、非空，且其 epoch 列覆盖 y_dir 下的
#     每一个 epoch 子目录。这样能挡住“扫描跑了一半就中断、txt 只写了前几个 epoch”
#     的情况——只看“文件非空”是挡不住的。
#   校验未过时默认保留 y_dir 并计入拦截；确认这些 epoch 数据不再需要（例如打算重跑
#   整个扫描、或已手动确认结果无用）时，用 --force 跳过该校验强行回收。
#   例外：y_dir 下若出现非 epoch 子目录（tmp/、backup/，以及 .backup/ 这类点号开头的
#   隐藏目录），说明它不是一棵纯 epoch 树，这些内容不可能出现在任何 p_post_epoch_*.txt
#   里 —— 属结构异常，永远拦截，--force 也不放行。真要删请自己看清楚后手动删。
#   注意：本检查只看【子目录】。直接躺在 y_dir 下的散落文件不在检查范围内，会随
#   y_dir 一起被回收。
#
# 安全：
#   * 默认 dry-run —— 只打印将删什么，绝不真删。看清后再加 --apply。
#   * 阶段 1 逐个明确路径 rm -- <file>，绝不递归 / 通配一把梭。
#   * 阶段 2 需要整棵树回收（单棵可达 ~78k 文件 / 22GB，逐文件 rm 不现实），
#     经用户明确授权，对【通过校验且路径形状匹配】的单个 y_dir 使用 rm -rf。
#     形状护栏见 check_safe_ydir()：必须是真目录（非符号链接）、位于 <root> 之下、
#     且绝对路径匹配 */y_post/*/properties/y_epoch_scan/y_dir。任一不满足即跳过。
#   * --force 只放行“txt 缺失 / txt 为空 / epoch 没覆盖全”这三类【内容不完整】。
#     它【绝不】放行形状护栏 —— rm -rf 的落点永远受 check_safe_ydir() 约束，符号链接 /
#     越界路径照样拒删；也【绝不】放行“y_dir 含非 epoch 子目录”这类结构异常。
#   * MPI 逐 rank 日志 (nnp-scaling.log.NNNN / nnp-train.log.NNNN)、
#     sf.*.histo、scaling.data 等【一律不碰】——它们不是按 epoch 编号，
#     “保留最后一个”对它们没有意义。
#   * y_epoch_scan 下的 p_post_epoch_*.{txt,pdf}、slurm-*.out、sub_slurm_*.sh 一律不碰。
#   * y_post 下的非 job 兄弟目录（如汇总图表 y_epoch_scan_summary）没有
#     properties/y_epoch_scan，直接跳过，不计入拦截、不影响退出码。
#
# 用法：
#   ./pei_n2p2_univ_clean_train <root>                 # dry-run，只看
#   ./pei_n2p2_univ_clean_train <root> --apply         # 真删
#   ./pei_n2p2_univ_clean_train <root> --size          # 顺便统计将释放的空间（慢）
#   ./pei_n2p2_univ_clean_train <root> --skip-post     # 只做阶段 1
#   ./pei_n2p2_univ_clean_train <root> --skip-train    # 只做阶段 2
#   ./pei_n2p2_univ_clean_train <root> --include-weights --apply   # 连 weights 也只留末尾
#   ./pei_n2p2_univ_clean_train <root> --force         # dry-run，看强删会波及哪些 job
#   ./pei_n2p2_univ_clean_train <root> --force --apply # 无视 epoch 覆盖校验，强行回收
#
# 退出码：
#   0   全部处理完毕，无待关注项
#   1   参数/结构错误，或阶段 2 有 job “y_dir 还在但校验未过”被拒绝删除（见 summary）。
#       此时 y_dir 被原样保留 —— 说明该 job 的 epoch 扫描没跑完，应先补跑 post，
#       而不是把源数据删掉。加 --force 可无视覆盖校验强删，此时这些 job 不再计入拦截，
#       但被形状护栏 / 结构异常拦下的仍然计入、仍以 1 退出。
# ================================================================
set -euo pipefail
shopt -s nullglob   # 无匹配的 glob 展开成空，而非字面量，方便数组判空

# ---- 配置：查表，不散写魔法字符串 ----
LFAMILY=( neuron-stats trainpoints testpoints trainforces testforces )  # 阶段 1：按 epoch 编号的诊断族
LREQ=( cij gsfe stretch )                                               # 阶段 2：必须齐备的 p_post_epoch_<name>.txt

# ---- check_epoch_coverage() 的退出码契约：--force 只放行 RC_COVERAGE_BAD ----
RC_COVERAGE_BAD=1  # 内容不完整：txt 缺失 / 为空 / epoch 没覆盖全。这些 epoch 数据本就是 post 的输入，可强删
RC_SHAPE_BAD=2     # 结构异常：y_dir 含非 epoch 子目录。它的内容不可能在任何 txt 里，永不强删

# ---- 运行态全局（编排层填写，helper 读取） ----
ROOT=""
APPLY=0            # 0=dry-run 只打印；1=真删
FORCE=0            # 阶段 2：1=跳过 epoch 覆盖校验强删（形状护栏仍生效）
INCLUDE_WEIGHTS=0  # 是否也裁剪 weights.<elem>.<epoch>.out
SKIP_TRAIN=0
SKIP_POST=0
WANT_SIZE=0        # 是否 du 统计体积（1M 文件时很慢，故默认关）
HAS_TRAIN=0        # <root>/y_dir  实际存在且未被 --skip-train 关掉
HAS_POST=0         # <root>/y_post 实际存在且未被 --skip-post  关掉

N_DEL=0            # 阶段 1：计划/实际删除文件数
N_KEEP=0           # 阶段 1：保留的文件数（各族末尾）
BYTES_FREED=0      # 阶段 1：释放（或将释放）的字节数

N_TREE=0           # 阶段 2：计划/实际删除的 y_dir 棵数
N_GONE=0           # 阶段 2：本就没有 y_dir（此前已清理）
N_NOJOB=0          # 阶段 2：不是 job 目录（无 properties/y_epoch_scan，如 y_epoch_scan_summary）
N_FORCED=0         # 阶段 2：校验未过、但被 --force 强行回收的 y_dir 棵数（N_TREE 的子集）
BYTES_TREE=0       # 阶段 2：释放（或将释放）的字节数
LBLOCKED=()        # 阶段 2：有 y_dir 但校验未过、被拒绝删除的目标 + 原因
LFORCED=()         # 阶段 2：被 --force 放行的目标 + 本该拦下它的原因

### helper: 错误 / 警告 -------------------------------------------------
fail() { printf '❌ ERROR: %s\n' "$1" >&2; exit 1; }
warn() { printf '⚠️  %s\n'      "$1" >&2; }

help() {
    cat <<'EOF'
================ 🧹 pei_n2p2_univ_clean_train
清理一个 n2p2 训练/扫描目录下的中间数据，默认 dry-run，不会真正删除。

用法：
  pei_n2p2_univ_clean_train <root> [选项]
  pei_n2p2_univ_clean_train help
  pei_n2p2_univ_clean_train -h|--help

典型示例：
  pei_n2p2_univ_clean_train <root>
  pei_n2p2_univ_clean_train <root> --apply
  pei_n2p2_univ_clean_train <root> --size
  pei_n2p2_univ_clean_train <root> --skip-post
  pei_n2p2_univ_clean_train <root> --skip-train
  pei_n2p2_univ_clean_train <root> --include-weights --apply --force
  pei_n2p2_univ_clean_train <root> --skip-train --force
  pei_n2p2_univ_clean_train <root> --skip-train --force --apply

处理阶段：
  阶段 1：裁剪 <root>/y_dir/* 下按 epoch 编号输出的诊断文件族，只保留末尾 epoch。
  阶段 2：回收 <root>/y_post/*/properties/y_epoch_scan/y_dir，前提是 post 汇总 txt
          齐备、非空，且 epoch 列覆盖 y_dir 下所有 epoch 子目录。

选项：
  --apply            真正执行删除；不加时只预览。
  --size             统计将释放/已释放的空间；目录很大时会较慢。
  --skip-train       跳过阶段 1，只处理 y_post。
  --skip-post        跳过阶段 2，只处理 y_dir。
  --include-weights  阶段 1 同时裁剪 weights.<elem>.<epoch>.out；默认全部保留。
  --force            阶段 2 跳过 epoch 覆盖校验并强行回收；形状护栏和结构异常仍会拦截。
  -h, --help, help   显示本帮助。

安全约束：
  * 阶段 1 只逐个删除明确文件路径。
  * 阶段 2 只回收路径形状匹配 */y_post/*/properties/y_epoch_scan/y_dir 的真实目录。
  * y_dir 含非 epoch 子目录时属于结构异常，即使用 --force 也不会回收。
  * dry-run 是默认模式；确认输出无误后再加 --apply。

退出码：
  0  全部处理完毕，无待关注项。
  1  参数/结构错误，或阶段 2 有被拦截的 y_dir 需要人工确认。
================
EOF
}

usage() {
    help
    exit "${1:-0}"
}

### helper: 人类可读大小 ------------------------------------------------
get_human_size() {
    # $1 = 字节数 → 尽量 IEC 化，无 numfmt 时退回原始字节
    if command -v numfmt >/dev/null 2>&1; then
        numfmt --to=iec --suffix=B "$1"
    else
        printf '%sB' "$1"
    fi
}

### helper: 目录体积（字节）。--size 未开时返回 0，避免百万文件 du 拖死 ----
get_tree_bytes() {
    (( WANT_SIZE )) || { printf '0'; return 0; }
    du -sb -- "$1" 2>/dev/null | awk '{print $1}' || printf '0'
}

# ================================================================ 阶段 1：y_dir 诊断族裁剪

### helper: 裁剪单个文件族（保留最大 epoch，删其余） --------------------
prune_family() {
    # $1 = 子目录绝对路径；$2 = 相对 glob（如 neuron-stats.*.out）；$3 = 展示标签
    local subdir="$1" pattern="$2" label="$3"
    local -a lfile
    lfile=( "$subdir"/$pattern )         # subdir 加引号、pattern 不加 → 让 glob 展开
    local n=${#lfile[@]}
    if (( n <= 1 )); then
        printf '   %-16s %d 个 → 无需处理\n' "$label:" "$n"
        (( n == 1 )) && { (( N_KEEP++ )) || true; }
        return 0
    fi

    # 文件名 epoch 已零填充，version 排序 == 数值排序；末元素 = 最大 epoch
    local -a lsorted
    mapfile -t lsorted < <(printf '%s\n' "${lfile[@]}" | sort -V)
    local last_idx=$(( ${#lsorted[@]} - 1 ))     # bash4.2 不支持 [-1]，显式算下标
    local keep="${lsorted[$last_idx]}"
    printf '   %-16s %d 个 → 保留 %s，删 %d\n' \
        "$label:" "$n" "$(basename "$keep")" "$(( n - 1 ))"
    (( N_KEEP++ )) || true

    local f sz
    for f in "${lsorted[@]}"; do
        [[ "$f" == "$keep" ]] && continue
        sz=$(stat -c %s -- "$f" 2>/dev/null || echo 0)
        (( BYTES_FREED += sz )) || true
        (( N_DEL++ ))           || true
        if (( APPLY )); then
            rm -- "$f"                                   # 逐个明确路径，绝不递归
            printf '      🗑  %s\n'          "$(basename "$f")"
        else
            printf '      [dry-run] 将删 %s\n' "$(basename "$f")"
        fi
    done
}

### helper: 裁剪 weights（先按元素分组，各组各留末尾 epoch） -------------
prune_weights() {
    # $1 = 子目录绝对路径。weights.<elem>.<epoch>.out —— 必须按 <elem> 分组，
    # 否则跨元素排序会误删别的元素的最终权重。
    local subdir="$1"
    local -a lw
    lw=( "$subdir"/weights.*.out )
    if (( ${#lw[@]} == 0 )); then
        printf '   %-16s 0 个 → 无需处理\n' "weights:"
        return 0
    fi
    local -a lelem
    mapfile -t lelem < <(printf '%s\n' "${lw[@]}" \
        | sed -E 's#.*/weights\.([0-9]+)\.[0-9]+\.out$#\1#' | sort -u)
    local elem
    for elem in "${lelem[@]}"; do
        prune_family "$subdir" "weights.${elem}.*.out" "weights.${elem}"
    done
}

### 阶段 1 编排 ---------------------------------------------------------
clean_train_dir() {
    # $1 = <root>/y_dir
    local ydir="$1"
    local -a lsubdir
    lsubdir=( "$ydir"/*/ )
    if (( ${#lsubdir[@]} == 0 )); then
        warn "$ydir 下没有子目录，阶段 1 无事可做。"
        return 0
    fi

    printf '\n================ 🧹 阶段 1：裁剪训练目录诊断文件\n'
    printf '📁 y_dir      : %s\n' "$ydir"
    printf '📊 子目录数   : %d\n' "${#lsubdir[@]}"
    printf '▶️  weights    : %s\n' "$( (( INCLUDE_WEIGHTS )) && echo '一并裁剪' || echo '保留全部（默认）' )"

    local subdir fam
    for subdir in "${lsubdir[@]}"; do
        printf '\n📁 %s\n' "$(basename "$subdir")"
        for fam in "${LFAMILY[@]}"; do
            prune_family "$subdir" "${fam}.*.out" "$fam"
        done
        # 必须写成 if，不能写 `(( X )) && cmd`：后者在 X=0 时让循环（进而让本函数）
        # 返回 1，被 set -e 当成失败，阶段 2 会被静默跳过。
        if (( INCLUDE_WEIGHTS )); then
            prune_weights "$subdir"
        fi
    done
    # to here: y_dir 下所有子目录处理完毕
    return 0
}

# ================================================================ 阶段 2：y_epoch_scan/y_dir 回收

### helper: 形状护栏 —— 只有长得完全对的路径才允许整棵回收 ---------------
check_safe_ydir() {
    # $1 = 待删目录。通过返回 0；否则 echo 原因并返回 1。
    local d="$1" rp
    [[ -L "$d" ]] && { echo "是符号链接，拒绝删除"; return 1; }
    [[ -d "$d" ]] || { echo "不是目录";           return 1; }
    rp="$(realpath -- "$d")"
    [[ "$rp" == "$ROOT"/* ]] \
        || { echo "解析后不在 <root> 之下：$rp"; return 1; }
    [[ "$rp" == */y_post/*/properties/y_epoch_scan/y_dir ]] \
        || { echo "路径形状不匹配 */y_post/*/properties/y_epoch_scan/y_dir：$rp"; return 1; }
    return 0
}

### helper: epoch 覆盖校验 ----------------------------------------------
check_epoch_coverage() {
    # $1 = y_epoch_scan 目录；$2 = 其下的 y_dir。
    # 通过返回 0；否则 echo 原因，并按退出码契约返回 RC_COVERAGE_BAD / RC_SHAPE_BAD。
    local scan="$1" ydir="$2"

    # 1) 枚举 y_dir 的直接子目录。必须开 dotglob：bash 的 * 默认跳过点号开头的项，
    #    .backup/ 之类会对下面的结构检查完全隐身，却照样被 rm -rf 一起带走。
    #    收进数组后立刻还原 dotglob：当前调用点是 $(...)（子 shell，本就隔离不到外面），
    #    但本函数不该依赖这一点 —— 校验循环里有 return，就地开关迟早漏给调用方。
    #    （dotglob 不会带入 ./ 与 ../，bash 显式排除。）
    local -a lentry
    local had_dotglob=0
    if shopt -q dotglob; then had_dotglob=1; fi
    shopt -s dotglob
    lentry=( "$ydir"/*/ )
    if (( ! had_dotglob )); then shopt -u dotglob; fi

    # 2) 子目录名必须全是 epoch 编号 → 十进制整数（10# 前缀，否则 000050 会被当八进制）
    #    出现非 epoch 子目录（tmp/、.backup/ 之类）说明这不是一棵纯 epoch 树：它的内容
    #    不可能被 p_post_epoch_*.txt 汇总走，删掉就是净损失。这是结构问题，不是
    #    “post 没跑完”，故用 RC_SHAPE_BAD 与内容不完整分开，--force 也不放行。
    local -a lepoch
    local d b
    if (( ${#lentry[@]} > 0 )); then    # bash 4.2 下 set -u + 空数组展开会报 unbound variable
        for d in "${lentry[@]}"; do
            b="$(basename "$d")"
            [[ "$b" =~ ^[0-9]+$ ]] \
                || { echo "y_dir 含非 epoch 子目录：$b"; return "$RC_SHAPE_BAD"; }
            lepoch+=( "$(( 10#$b ))" )
        done
    fi
    if (( ${#lepoch[@]} == 0 )); then
        echo "y_dir 下没有 epoch 子目录"    # 空壳目录：交给调用方当作可删
        return 0
    fi

    # 3) 逐个必需 txt：存在、非空、epoch 列覆盖所有 epoch 子目录
    local name txt e
    for name in "${LREQ[@]}"; do
        txt="$scan/p_post_epoch_${name}.txt"
        [[ -f "$txt" ]] || { echo "缺少 p_post_epoch_${name}.txt"; return "$RC_COVERAGE_BAD"; }
        [[ -s "$txt" ]] || { echo "p_post_epoch_${name}.txt 为空"; return "$RC_COVERAGE_BAD"; }

        # 数据行首列即 epoch；表头 "epoch" 非数字，天然被过滤掉
        local -A dict_have=()
        while read -r e; do dict_have["$e"]=1; done \
            < <(awk '$1 ~ /^[0-9]+$/ {print $1+0}' "$txt")

        for e in "${lepoch[@]}"; do
            [[ -n "${dict_have[$e]:-}" ]] \
                || { echo "p_post_epoch_${name}.txt 未覆盖 epoch $e"; return "$RC_COVERAGE_BAD"; }
        done
    done
    return 0
}

### helper: 回收单棵 y_dir ----------------------------------------------
delete_epoch_ydir() {
    # $1 = 已通过 check_safe_ydir 的目录
    local rp; rp="$(realpath -- "$1")"
    local sz; sz="$(get_tree_bytes "$rp")"
    (( BYTES_TREE += sz )) || true
    (( N_TREE++ ))         || true

    if (( APPLY )); then
        rm -rf -- "$rp"      # 唯一的递归删除点：路径已过形状护栏 + epoch 覆盖校验
        printf '   🗑  已回收 y_dir%s\n' "$( (( WANT_SIZE )) && echo "（$(get_human_size "$sz")）" )"
    else
        printf '   [dry-run] 将回收 y_dir%s\n' "$( (( WANT_SIZE )) && echo "（$(get_human_size "$sz")）" )"
    fi
}

### 阶段 2 编排 ---------------------------------------------------------
clean_post_dir() {
    # $1 = <root>/y_post
    local ypost="$1"
    local -a lsubdir
    lsubdir=( "$ypost"/*/ )
    if (( ${#lsubdir[@]} == 0 )); then
        warn "$ypost 下没有子目录，阶段 2 无事可做。"
        return 0
    fi

    printf '\n================ 🧹 阶段 2：回收 y_epoch_scan/y_dir\n'
    printf '📁 y_post     : %s\n' "$ypost"
    printf '📊 子目录数   : %d\n' "${#lsubdir[@]}"
    printf '▶️  判定条件   : p_post_epoch_{%s}.txt 齐备、非空、epoch 列全覆盖%s\n' \
        "$(printf '%s,' "${LREQ[@]}" | sed 's/,$//')" \
        "$( (( FORCE )) && echo '（--force：仅提示，不拦截）' )"

    local subdir job scan ydir reason passed force_reason rc
    for subdir in "${lsubdir[@]}"; do
        job="$(basename "$subdir")"
        scan="${subdir}properties/y_epoch_scan"
        ydir="$scan/y_dir"
        printf '\n📁 %s\n' "$job"

        # y_post 下混有非 job 的兄弟目录（如 y_epoch_scan_summary 汇总图表）。
        # 它们没有 y_dir，本就无数据可丢，只做提示，不计入 blocked、不影响退出码。
        if [[ ! -d "$scan" ]]; then
            printf '   ⏭  无 properties/y_epoch_scan，非 job 目录，跳过\n'
            (( N_NOJOB++ )) || true
            continue
        fi
        if [[ ! -e "$ydir" ]]; then
            printf '   ✅ 已无 y_dir（此前已清理）\n'
            (( N_GONE++ )) || true
            continue
        fi

        # 业务内容检查下推到此处：先校验 post 结果完整，再看路径形状。
        # --force 下仍然跑校验（成本可忽略），只为把“本该拦下你的原因”原样打出来 ——
        # 强删也要看清删的是什么，不能变成静默通过。
        passed=1
        force_reason=""
        rc=0
        # 必须用 `|| rc=$?` 取码：写成 `if ! reason=$(...)` 的话 then 分支里的 $? 已被 ! 取反
        reason="$(check_epoch_coverage "$scan" "$ydir")" || rc=$?
        if (( rc == RC_SHAPE_BAD )); then
            # 结构异常不是“数据不完整”，--force 无权放行：里面的东西从没被 post 提取过
            printf '   ❌ 结构异常：%s（--force 不放行）\n' "$reason"
            LBLOCKED+=( "$job: $reason" )
            continue
        elif (( rc )); then
            passed=0
            if (( ! FORCE )); then
                printf '   ❌ 校验未过：%s\n' "$reason"
                LBLOCKED+=( "$job: $reason" )
                continue
            fi
            printf '   ⚠️  校验未过：%s → --force 强行回收\n' "$reason"
            force_reason="$reason"
        fi

        # 形状护栏永远生效：--force 放行的是“数据完不完整”，不是“该不该 rm -rf 这个路径”
        if ! reason="$(check_safe_ydir "$ydir")"; then
            printf '   ❌ 护栏拦截：%s\n' "$reason"
            LBLOCKED+=( "$job: $reason" )
            continue
        fi

        if (( passed )); then
            printf '   ✅ 校验通过（p_post_epoch_*.txt 齐备且覆盖全部 epoch）\n'
        else
            # 计数落在护栏之后：被护栏拦下的不算“已强删”，N_FORCED 始终是 N_TREE 的子集
            LFORCED+=( "$job: $force_reason" )
            (( N_FORCED++ )) || true
        fi
        delete_epoch_ydir "$ydir"
    done
    # to here: y_post 下所有子目录处理完毕
    return 0
}

